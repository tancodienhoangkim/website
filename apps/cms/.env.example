DATABASE_URL=postgres://hoangkim_tcd:hoangkim_tcd@localhost:5432/hoangkim_tcd_cms

# Payload secret — 48+ random chars. Generate: `openssl rand -base64 48`
PAYLOAD_SECRET=

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Optional HTTP Basic Auth gate in front of /admin. Leave empty in dev.
# Production format "user:pass" — middleware base64-encodes for comparison.
# Tip: use a long random password you keep in a team secret manager.
ADMIN_BASIC_AUTH=

# Cloudflare R2 / S3 media storage (leave blank for local FS in dev)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# Admin seed credentials — REQUIRED for `pnpm seed` to succeed.
# SEED_ADMIN_PASSWORD min 16 chars. Generate: `openssl rand -base64 24`
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Plan F analytics (all optional)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
