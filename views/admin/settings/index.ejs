<h2>Cài đặt</h2>
<div class="card"><div class="card-body">
  <form action="/admin/settings?_method=PUT&_csrf=<%= encodeURIComponent(csrfToken) %>" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h5>Thông tin chung</h5><hr>
    <div class="form-group"><label>Tên website</label><input type="text" name="siteName" class="form-control" value="<%= settings.siteName || '' %>"></div>
    <div class="form-group"><label>Logo</label><input type="file" name="logo" class="form-control-file" accept="image/*"><% if (settings.logo) { %><img src="<%= settings.logo %>" alt="Logo" class="mt-2" style="max-height:60px;"><% } %></div>
    <div class="row">
      <div class="col-md-6"><div class="form-group"><label>Số điện thoại</label><input type="text" name="phone" class="form-control" value="<%= settings.phone || '' %>"></div></div>
      <div class="col-md-6"><div class="form-group"><label>Email</label><input type="email" name="email" class="form-control" value="<%= settings.email || '' %>"></div></div>
    </div>
    <div class="form-group"><label>Địa chỉ</label><input type="text" name="address" class="form-control" value="<%= settings.address || '' %>"></div>
    <div class="form-group"><label>Google Maps Embed URL</label><input type="text" name="googleMapsEmbed" class="form-control" value="<%= settings.googleMapsEmbed || '' %>"></div>
    <div class="form-group"><label>Footer text</label><textarea name="footerText" class="form-control" rows="2"><%= settings.footerText || '' %></textarea></div>
    <h5 class="mt-4">SEO</h5><hr>
    <div class="form-group"><label>Meta Title</label><input type="text" name="metaTitle" class="form-control" value="<%= settings.metaTitle || '' %>"></div>
    <div class="form-group"><label>Meta Description</label><textarea name="metaDescription" class="form-control" rows="2"><%= settings.metaDescription || '' %></textarea></div>
    <h5 class="mt-4">Mạng xã hội</h5><hr>
    <div class="row">
      <div class="col-md-4"><div class="form-group"><label><i class="fab fa-facebook"></i> Facebook</label><input type="text" name="facebook" class="form-control" value="<%= settings.facebook || '' %>"></div></div>
      <div class="col-md-4"><div class="form-group"><label>Zalo</label><input type="text" name="zalo" class="form-control" value="<%= settings.zalo || '' %>"></div></div>
      <div class="col-md-4"><div class="form-group"><label><i class="fab fa-youtube"></i> YouTube</label><input type="text" name="youtube" class="form-control" value="<%= settings.youtube || '' %>"></div></div>
    </div>
    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu cài đặt</button>
  </form>
</div></div>
