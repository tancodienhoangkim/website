<h2>Dashboard</h2>
<div class="row">
  <div class="col-md-3 mb-3">
    <div class="card text-white bg-primary">
      <div class="card-body">
        <h5 class="card-title"><i class="fas fa-building"></i> Dự án</h5>
        <h2><%= projectCount %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="card text-white bg-success">
      <div class="card-body">
        <h5 class="card-title"><i class="fas fa-newspaper"></i> Bài viết</h5>
        <h2><%= postCount %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="card text-white bg-info">
      <div class="card-body">
        <h5 class="card-title"><i class="fas fa-envelope"></i> Liên hệ</h5>
        <h2><%= contactCount %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="card text-white bg-warning">
      <div class="card-body">
        <h5 class="card-title"><i class="fas fa-bell"></i> Chưa đọc</h5>
        <h2><%= unreadCount %></h2>
      </div>
    </div>
  </div>
</div>
