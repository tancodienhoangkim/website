<h2><%= testimonial ? 'Sửa' : 'Thêm' %> đánh giá</h2>
<div class="card"><div class="card-body">
  <form action="<%= testimonial ? '/admin/testimonials/' + testimonial._id + '?_method=PUT&_csrf=' + encodeURIComponent(csrfToken) : '/admin/testimonials?_csrf=' + encodeURIComponent(csrfToken) %>" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-group"><label>Tên khách hàng <span class="text-danger">*</span></label><input type="text" name="name" class="form-control" value="<%= testimonial ? testimonial.name : '' %>" required></div>
    <div class="form-group"><label>Chức vụ / Công ty</label><input type="text" name="role" class="form-control" value="<%= testimonial ? testimonial.role : '' %>" placeholder="VD: CEO, Công ty ABC"></div>
    <div class="form-group"><label>Nội dung đánh giá <span class="text-danger">*</span></label><textarea name="content" class="form-control" rows="4" required><%= testimonial ? testimonial.content : '' %></textarea></div>
    <div class="form-group"><label>Avatar</label><input type="file" name="avatar" class="form-control-file" accept="image/*"><% if (testimonial && testimonial.avatar) { %><img src="<%= testimonial.avatar %>" alt="" class="mt-2" style="width:60px;height:60px;border-radius:50%;object-fit:cover;"><% } %></div>
    <div class="row">
      <div class="col-md-6"><div class="form-group"><label>Thứ tự</label><input type="number" name="order" class="form-control" value="<%= testimonial ? testimonial.order : 0 %>"></div></div>
      <div class="col-md-6"><div class="form-group"><label>Trạng thái</label><select name="status" class="form-control"><option value="draft" <%= testimonial && testimonial.status === 'draft' ? 'selected' : '' %>>Nháp</option><option value="published" <%= testimonial && testimonial.status === 'published' ? 'selected' : '' %>>Xuất bản</option></select></div></div>
    </div>
    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu</button>
    <a href="/admin/testimonials" class="btn btn-secondary">Hủy</a>
  </form>
</div></div>
