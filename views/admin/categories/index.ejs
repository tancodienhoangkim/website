<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Danh mục</h2>
  <a href="/admin/categories/create" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm mới</a>
</div>
<table class="table table-bordered bg-white">
  <thead class="thead-light">
    <tr><th>Tên</th><th>Loại</th><th>Danh mục cha</th><th>Thứ tự</th><th width="150">Hành động</th></tr>
  </thead>
  <tbody>
    <% categories.forEach(cat => { %>
    <tr>
      <td><%= cat.name %></td>
      <td><span class="badge badge-info"><%= cat.type %></span></td>
      <td><%= cat.parent ? cat.parent.name : '—' %></td>
      <td><%= cat.order %></td>
      <td>
        <a href="/admin/categories/<%= cat._id %>/edit" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
        <form action="/admin/categories/<%= cat._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Xóa?')">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
        </form>
      </td>
    </tr>
    <% }) %>
    <% if (!categories.length) { %><tr><td colspan="5" class="text-center text-muted">Chưa có danh mục</td></tr><% } %>
  </tbody>
</table>
