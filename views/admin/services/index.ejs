<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Dịch vụ</h2>
  <a href="/admin/services/create" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm mới</a>
</div>
<table class="table table-bordered bg-white">
  <thead class="thead-light">
    <tr><th>Ảnh</th><th>Tên</th><th>Icon</th><th>Thứ tự</th><th>Trạng thái</th><th width="150">Hành động</th></tr>
  </thead>
  <tbody>
    <% services.forEach(s => { %>
    <tr>
      <td><% if (s.image) { %><img src="<%= s.image %>" alt=""><% } else { %>—<% } %></td>
      <td><%= s.title %></td>
      <td><% if (s.icon) { %><i class="<%= s.icon %>"></i><% } %> <%= s.icon %></td>
      <td><%= s.order %></td>
      <td><span class="badge badge-<%= s.status === 'published' ? 'success' : 'secondary' %>"><%= s.status %></span></td>
      <td>
        <a href="/admin/services/<%= s._id %>/edit" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
        <form action="/admin/services/<%= s._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Xóa?')">
          <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
        </form>
      </td>
    </tr>
    <% }) %>
    <% if (!services.length) { %><tr><td colspan="6" class="text-center text-muted">Chưa có dịch vụ</td></tr><% } %>
  </tbody>
</table>
