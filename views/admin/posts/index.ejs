<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>Bài viết</h2>
  <a href="/admin/posts/create" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm mới</a>
</div>
<table class="table table-bordered bg-white">
  <thead class="thead-light">
    <tr><th>Ảnh</th><th>Tiêu đề</th><th>Danh mục</th><th>Ngày tạo</th><th>Trạng thái</th><th width="150">Hành động</th></tr>
  </thead>
  <tbody>
    <% posts.forEach(p => { %>
    <tr>
      <td><% if (p.thumbnail) { %><img src="<%= p.thumbnail %>" alt=""><% } else { %>—<% } %></td>
      <td><%= p.title %></td>
      <td><%= p.category ? p.category.name : '—' %></td>
      <td><%= p.createdAt.toLocaleDateString('vi-VN') %></td>
      <td><span class="badge badge-<%= p.status === 'published' ? 'success' : 'secondary' %>"><%= p.status %></span></td>
      <td>
        <a href="/admin/posts/<%= p._id %>/edit" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
        <form action="/admin/posts/<%= p._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Xóa?')">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
        </form>
      </td>
    </tr>
    <% }) %>
    <% if (!posts.length) { %><tr><td colspan="6" class="text-center text-muted">Chưa có bài viết</td></tr><% } %>
  </tbody>
</table>
