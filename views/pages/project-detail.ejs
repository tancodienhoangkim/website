<section class="page-header" style="background:linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.6)),url('<%= project.thumbnail %>');background-size:cover;background-position:center;">
  <div class="container text-center text-white py-5"><h1><%= project.title %></h1></div>
</section>
<section class="py-5"><div class="container"><div class="row">
  <div class="col-lg-8">
    <div class="project-gallery mb-4"><div class="row">
      <% project.images.forEach((img, i) => { %>
      <div class="col-md-6 mb-3"><a href="<%= img %>" data-fancybox="gallery" data-caption="<%= project.title %> - Ảnh <%= i + 1 %>"><img src="<%= img %>" alt="<%= project.title %>" class="img-fluid rounded"></a></div>
      <% }) %>
    </div></div>
    <div class="project-description"><%- project.description %></div>
    <% if (project.videoUrl) { %><div class="mt-4"><a href="<%= project.videoUrl %>" data-fancybox class="btn btn-outline-primary"><i class="fas fa-play"></i> Xem video</a></div><% } %>
  </div>
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header"><h5 class="mb-0">Thông tin dự án</h5></div>
      <ul class="list-group list-group-flush">
        <% if (project.style) { %><li class="list-group-item"><strong>Phong cách:</strong> <%= project.style %></li><% } %>
        <% if (project.type) { %><li class="list-group-item"><strong>Loại:</strong> <%= project.type %></li><% } %>
        <% if (project.area) { %><li class="list-group-item"><strong>Diện tích:</strong> <%= project.area %></li><% } %>
        <% if (project.location) { %><li class="list-group-item"><strong>Địa điểm:</strong> <%= project.location %></li><% } %>
        <% if (project.category) { %><li class="list-group-item"><strong>Danh mục:</strong> <%= project.category.name %></li><% } %>
      </ul>
    </div>
    <div class="card mt-3"><div class="card-body text-center"><h5>Bạn thích thiết kế này?</h5><a href="/lien-he" class="btn btn-primary btn-block">Nhận tư vấn miễn phí</a><p class="mt-2 mb-0"><i class="fas fa-phone-alt"></i> <%= settings.phone || '' %></p></div></div>
  </div>
</div>
<% if (related.length) { %><hr class="my-5"><h3 class="text-center mb-4">Dự án liên quan</h3><div class="row"><% related.forEach(p => { %><div class="col-md-3 mb-4"><%- include('../partials/project-card', { project: p }) %></div><% }) %></div><% } %>
</div></section>
