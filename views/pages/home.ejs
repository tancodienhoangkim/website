<%
  function stripHtml(html) {
    return String(html || '').replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
  }

  function truncate(text, maxLength) {
    if (!text) return '';
    return text.length > maxLength ? text.slice(0, maxLength - 1).trim() + '...' : text;
  }

  function typeLabel(type) {
    if (type === 'biet-thu') return 'Biệt thự';
    if (type === 'lau-dai') return 'Lâu đài';
    if (type === 'dinh-thu') return 'Dinh thự';
    if (type === 'nha-pho') return 'Nhà phố';
    return 'Kiến trúc';
  }

  function formatDate(date) {
    if (!date) return '';
    return new Date(date).toLocaleDateString('vi-VN');
  }

  const brandName = settings.siteName || 'Tân Cổ Điển Hoàng Kim';
  const displayPhone = settings.phone || '0966.888.000';
  const displayAddress = settings.address || 'Đồng hành cùng gia chủ trên toàn quốc';
  const heroSource = featuredProjects.length ? featuredProjects : (constructionProjects.length ? constructionProjects : interiorProjects);
  const heroProjects = heroSource.slice(0, 3);
  const serviceCards = services.slice(0, 4);
  const architectureProjects = (featuredProjects.length ? featuredProjects : heroSource).slice(0, 6);
  const mansionProjects = heroSource.filter(project => project.type === 'lau-dai' || project.type === 'dinh-thu');
  const mansionShowcase = (mansionProjects.length ? mansionProjects : architectureProjects).slice(0, 4);
  const interiorShowcase = interiorProjects.slice(0, 4);
  const constructionShowcase = constructionProjects.slice(0, 4);
  const primaryVideo = videosProjects[0] || null;
  const secondaryVideos = videosProjects.slice(1, 3);
  const latestPosts = posts.slice(0, 3);
  const leadTestimonial = testimonials[0] || null;
  const serviceHighlights = serviceCards.slice(0, 3);
  const hasMediaRail = pressLogos.length || partners.length;
  const trustMetrics = [
    { value: 12, suffix: '+', label: 'Năm kinh nghiệm chuyên sâu' },
    { value: 1000, suffix: '+', label: 'Công trình đã triển khai' },
    { value: 3, suffix: ' miền', label: 'Dự án phủ rộng toàn quốc' },
    { value: 24, suffix: '/7', label: 'Tư vấn đồng hành liên tục' },
  ];
%>

<div class="home-akisa">
  <section class="hk-hero">
    <% if (heroProjects.length) { %>
      <div class="owl-carousel hero-carousel hk-hero-carousel">
        <% heroProjects.forEach((project, index) => { %>
          <article class="hk-hero-slide" style="background-image:url('<%= project.thumbnail || 'https://picsum.photos/seed/homehero/1800/1000' %>')">
            <div class="hk-hero-slide__scrim"></div>
            <div class="container hk-hero-slide__inner">
              <div class="row align-items-end">
                <div class="col-xl-7 col-lg-8">
                  <div class="hk-hero-copy" data-aos="fade-up">
                    <span class="hk-kicker">Thiết kế kiến trúc • Nội thất • Thi công trọn gói</span>
                    <h1>Kiến tạo biệt thự, dinh thự và không gian sống đậm dấu ấn gia chủ.</h1>
                    <p><%= project.title %><% if (project.location) { %> tại <%= project.location %><% } %> là một trong những dự án tiêu biểu thể hiện rõ tư duy thiết kế đồng bộ, ngôn ngữ thẩm mỹ chỉn chu và năng lực triển khai thực tế của <%= brandName %>.</p>
                    <div class="hk-hero-copy__actions">
                      <a href="/du-an/<%= project.slug %>" class="btn btn-primary btn-lg">Xem dự án nổi bật</a>
                      <a href="/lien-he" class="btn btn-outline-light btn-lg">Nhận tư vấn miễn phí</a>
                    </div>
                  </div>
                </div>
                <div class="col-xl-4 offset-xl-1 col-lg-4">
                  <aside class="hk-hero-panel" data-aos="fade-left" data-aos-delay="<%= 120 + (index * 40) %>">
                    <span class="hk-hero-panel__label">Hồ sơ năng lực</span>
                    <h3><%= brandName %></h3>
                    <p>Tập trung vào dòng công trình cao cấp với giải pháp thiết kế, thi công và hoàn thiện đồng nhất từ tổng thể kiến trúc đến từng chi tiết nội thất.</p>
                    <ul class="hk-hero-panel__list">
                      <li><strong>Loại hình:</strong> <%= typeLabel(project.type) %></li>
                      <% if (project.area) { %><li><strong>Diện tích:</strong> <%= project.area %></li><% } %>
                      <% if (project.location) { %><li><strong>Khu vực:</strong> <%= project.location %></li><% } %>
                      <li><strong>Hotline:</strong> <%= displayPhone %></li>
                    </ul>
                  </aside>
                </div>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <article class="hk-hero-slide hk-hero-slide--fallback">
        <div class="hk-hero-slide__scrim"></div>
        <div class="container hk-hero-slide__inner">
          <div class="row align-items-end">
            <div class="col-xl-7 col-lg-8">
              <div class="hk-hero-copy" data-aos="fade-up">
                <span class="hk-kicker">Thiết kế kiến trúc • Nội thất • Thi công trọn gói</span>
                <h1>Kiến tạo không gian sống sang trọng, cân bằng giữa tỷ lệ kiến trúc và trải nghiệm sử dụng.</h1>
                <p><%= brandName %> theo đuổi ngôn ngữ thẩm mỹ chỉn chu, bố cục mạch lạc và cách triển khai nhất quán từ ý tưởng cho đến công trình thực tế.</p>
                <div class="hk-hero-copy__actions">
                  <a href="/thiet-ke-kien-truc" class="btn btn-primary btn-lg">Khám phá thư viện dự án</a>
                  <a href="/lien-he" class="btn btn-outline-light btn-lg">Đặt lịch tư vấn</a>
                </div>
              </div>
            </div>
            <div class="col-xl-4 offset-xl-1 col-lg-4">
              <aside class="hk-hero-panel" data-aos="fade-left">
                <span class="hk-hero-panel__label">Tư vấn nhanh</span>
                <h3><%= brandName %></h3>
                <p>Thiết kế dành cho nhóm khách hàng cần một đơn vị có khả năng kiểm soát tốt cả thẩm mỹ, kỹ thuật và tiến độ thi công.</p>
                <ul class="hk-hero-panel__list">
                  <li><strong>Dịch vụ:</strong> Kiến trúc, nội thất, thi công</li>
                  <li><strong>Khu vực:</strong> <%= displayAddress %></li>
                  <li><strong>Hotline:</strong> <%= displayPhone %></li>
                </ul>
              </aside>
            </div>
          </div>
        </div>
      </article>
    <% } %>
  </section>

  <section class="hk-brand section-stats">
    <div class="container">
      <div class="hk-brand__shell">
        <div class="hk-brand__intro" data-aos="fade-up">
          <span class="hk-kicker">Giới thiệu thương hiệu</span>
          <h2>Tư duy bố cục được làm lại theo hướng một studio kiến trúc quy mô lớn: nhiều lớp nội dung, giàu bằng chứng và dày thư viện dự án.</h2>
          <p><%= brandName %> tập trung phát triển hệ hình ảnh thương hiệu cao cấp, nhấn mạnh vào chiều sâu chuyên môn, khả năng triển khai đồng bộ và trải nghiệm tư vấn rõ ràng cho gia chủ ngay từ trang đầu tiên.</p>
          <p>Từ thiết kế kiến trúc, nội thất đến thi công hoàn thiện, toàn bộ hành trình được sắp xếp thành các cụm nội dung tách bạch để người xem dễ quét, dễ tin tưởng và dễ đi tới bước liên hệ hơn.</p>
          <div class="hk-brand__actions">
            <a href="/gioi-thieu" class="btn btn-primary">Tìm hiểu về chúng tôi</a>
            <a href="/thiet-ke-kien-truc" class="btn btn-outline-primary">Xem thư viện công trình</a>
          </div>
          <div class="hk-brand__list">
            <% if (serviceHighlights.length) { %>
              <% serviceHighlights.forEach(service => { %>
                <span><i class="fas fa-check-circle"></i> <%= service.title %></span>
              <% }) %>
            <% } else { %>
              <span><i class="fas fa-check-circle"></i> Thiết kế kiến trúc biệt thự, dinh thự, nhà phố</span>
              <span><i class="fas fa-check-circle"></i> Thiết kế nội thất đồng bộ phong cách sống</span>
              <span><i class="fas fa-check-circle"></i> Thi công trọn gói với quy trình rõ ràng</span>
            <% } %>
          </div>
        </div>
        <div class="hk-brand__metrics" data-aos="fade-left">
          <% trustMetrics.forEach((metric, index) => { %>
            <div class="hk-metric-card" data-aos="fade-up" data-aos-delay="<%= 80 * (index + 1) %>">
              <div class="hk-metric-card__value stat-number" data-count="<%= metric.value %>" data-suffix="<%= metric.suffix %>"><%= metric.value.toLocaleString('vi-VN') %><%= metric.suffix %></div>
              <div class="hk-metric-card__label"><%= metric.label %></div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </section>

  <% if (serviceCards.length) { %>
    <section class="hk-services">
      <div class="container">
        <div class="hk-section-heading text-center" data-aos="fade-up">
          <span class="hk-kicker">Hệ dịch vụ chủ lực</span>
          <h2>Đẩy các trụ cột kinh doanh lên cao để homepage vừa mạnh về thương hiệu, vừa rõ đường dẫn cho từng nhu cầu tư vấn.</h2>
        </div>
        <div class="row hk-service-grid">
          <% serviceCards.forEach((service, index) => { %>
            <div class="col-lg-3 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="<%= 80 * index %>">
              <article class="hk-service-card">
                <div class="hk-service-card__media">
                  <% if (service.image) { %>
                    <img src="<%= service.image %>" alt="<%= service.title %>">
                  <% } else { %>
                    <div class="hk-service-card__icon"><i class="<%= service.icon || 'fas fa-drafting-compass' %>"></i></div>
                  <% } %>
                  <span class="hk-service-card__index">0<%= index + 1 %></span>
                </div>
                <div class="hk-service-card__body">
                  <h3><%= service.title %></h3>
                  <p><%= truncate(stripHtml(service.description), 135) %></p>
                  <a href="/dich-vu/<%= service.slug %>" class="hk-inline-link">Khám phá dịch vụ</a>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      </div>
    </section>
  <% } %>

  <% if (primaryVideo) { %>
    <section class="hk-video-spotlight">
      <div class="container">
        <div class="row align-items-stretch">
          <div class="col-lg-7 mb-4 mb-lg-0" data-aos="fade-up">
            <a href="<%= primaryVideo.videoUrl %>" data-fancybox="videos" class="hk-video-lead">
              <img src="<%= primaryVideo.thumbnail || 'https://picsum.photos/seed/videohero/1200/760' %>" alt="<%= primaryVideo.title %>">
              <span class="hk-video-lead__play"><i class="fas fa-play"></i></span>
              <div class="hk-video-lead__copy">
                <span class="hk-kicker">Video nổi bật</span>
                <h3><%= primaryVideo.title %></h3>
              </div>
            </a>
          </div>
          <div class="col-lg-5">
            <div class="hk-video-side" data-aos="fade-left">
              <span class="hk-kicker">Công trình thực tế</span>
              <h2>Video đóng vai trò như một lớp bằng chứng sống, giúp thương hiệu có chiều sâu và cảm giác vận hành thật hơn.</h2>
              <p>Phần này được thiết kế như một “điểm dừng nhịp” giữa các cụm portfolio, tạo cảm giác giàu nội dung giống những website kiến trúc lớn có kho dự án và tư liệu thi công sâu.</p>
              <% secondaryVideos.forEach(video => { %>
                <a href="<%= video.videoUrl %>" data-fancybox="videos" class="hk-video-side__item">
                  <img src="<%= video.thumbnail || 'https://picsum.photos/seed/videoside/400/260' %>" alt="<%= video.title %>">
                  <div>
                    <h4><%= truncate(video.title, 80) %></h4>
                    <span>Xem video</span>
                  </div>
                </a>
              <% }) %>
              <a href="/thi-cong" class="btn btn-outline-light">Xem thêm công trình thực tế</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  <% } %>

  <% if (architectureProjects.length) { %>
    <section class="hk-showcase hk-showcase--architecture">
      <div class="container">
        <div class="hk-section-heading hk-section-heading--split" data-aos="fade-up">
          <div>
            <span class="hk-kicker">Kho dự án kiến trúc</span>
            <h2>Nhấn mạnh cảm giác “thư viện công trình” với tiêu đề mạnh, cụm bộ lọc nhanh và lưới dự án hiển thị rõ quy mô.</h2>
          </div>
          <a href="/thiet-ke-kien-truc" class="btn btn-outline-primary">Xem toàn bộ</a>
        </div>
        <div class="hk-chip-row" data-aos="fade-up" data-aos-delay="80">
          <a href="/thiet-ke-kien-truc?style=tan-co-dien" class="hk-chip">Biệt thự tân cổ điển</a>
          <a href="/thiet-ke-kien-truc?style=co-dien-phap" class="hk-chip">Cổ điển Pháp</a>
          <a href="/thiet-ke-kien-truc?style=hien-dai" class="hk-chip">Hiện đại</a>
          <a href="/thiet-ke-kien-truc?type=lau-dai" class="hk-chip">Lâu đài - dinh thự</a>
          <a href="/thiet-ke-kien-truc?type=biet-thu" class="hk-chip">Biệt thự sân vườn</a>
        </div>
        <div class="row">
          <% architectureProjects.forEach((project, index) => { %>
            <div class="col-lg-4 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="<%= (index % 3) * 80 %>">
              <article class="hk-project-card">
                <a href="/du-an/<%= project.slug %>" class="hk-project-card__media">
                  <img src="<%= project.thumbnail || 'https://picsum.photos/seed/archproject/800/620' %>" alt="<%= project.title %>" loading="lazy">
                  <span class="hk-project-card__tag"><%= typeLabel(project.type) %></span>
                </a>
                <div class="hk-project-card__body">
                  <h3><a href="/du-an/<%= project.slug %>"><%= project.title %></a></h3>
                  <p><%= truncate(stripHtml(project.description), 115) %></p>
                  <div class="hk-project-card__meta">
                    <% if (project.location) { %><span><i class="fas fa-map-marker-alt"></i> <%= project.location %></span><% } %>
                    <% if (project.area) { %><span><i class="fas fa-ruler-combined"></i> <%= project.area %></span><% } %>
                  </div>
                </div>
              </article>
            </div>
          <% }) %>
        </div>
      </div>
    </section>
  <% } %>

  <% if (mansionShowcase.length || interiorShowcase.length) { %>
    <section class="hk-dual-catalog">
      <div class="container">
        <div class="row">
          <% if (mansionShowcase.length) { %>
            <div class="col-lg-6 mb-4" data-aos="fade-up">
              <section class="hk-catalog-block">
                <div class="hk-section-heading">
                  <span class="hk-kicker">Lâu đài - dinh thự</span>
                  <h2>Tách riêng nhóm công trình biểu tượng để tăng cảm giác quy mô, chiều sâu và tính phân cấp như một hub danh mục thực thụ.</h2>
                </div>
                <div class="hk-catalog-list">
                  <% mansionShowcase.forEach(project => { %>
                    <a href="/du-an/<%= project.slug %>" class="hk-catalog-item">
                      <img src="<%= project.thumbnail || 'https://picsum.photos/seed/mansion/320/240' %>" alt="<%= project.title %>" loading="lazy">
                      <div>
                        <span class="hk-catalog-item__tag"><%= typeLabel(project.type) %></span>
                        <h3><%= truncate(project.title, 74) %></h3>
                        <% if (project.location) { %><p><i class="fas fa-map-marker-alt"></i> <%= project.location %></p><% } %>
                      </div>
                    </a>
                  <% }) %>
                </div>
              </section>
            </div>
          <% } %>
          <% if (interiorShowcase.length) { %>
            <div class="col-lg-6 mb-4" data-aos="fade-up" data-aos-delay="80">
              <section class="hk-catalog-block hk-catalog-block--warm">
                <div class="hk-section-heading">
                  <span class="hk-kicker">Thiết kế nội thất</span>
                  <h2>Khối nội thất đặt song song với kiến trúc giúp trang chủ có đúng nhịp kể chuyện của một thương hiệu làm trọn gói.</h2>
                </div>
                <div class="row">
                  <% interiorShowcase.forEach(project => { %>
                    <div class="col-sm-6 mb-4">
                      <article class="hk-mini-project">
                        <a href="/du-an/<%= project.slug %>">
                          <img src="<%= project.thumbnail || 'https://picsum.photos/seed/interior/500/420' %>" alt="<%= project.title %>" loading="lazy">
                          <div class="hk-mini-project__body">
                            <h3><%= truncate(project.title, 58) %></h3>
                            <% if (project.location) { %><span><i class="fas fa-map-marker-alt"></i> <%= project.location %></span><% } %>
                          </div>
                        </a>
                      </article>
                    </div>
                  <% }) %>
                </div>
                <a href="/thiet-ke-noi-that" class="btn btn-outline-primary">Khám phá nội thất</a>
              </section>
            </div>
          <% } %>
        </div>
      </div>
    </section>
  <% } %>

  <% if (constructionShowcase.length || leadTestimonial) { %>
    <section class="hk-construction">
      <div class="container">
        <div class="row align-items-start">
          <% if (constructionShowcase.length) { %>
            <div class="col-lg-7 mb-4" data-aos="fade-up">
              <div class="hk-section-heading">
                <span class="hk-kicker">Thi công thực tế</span>
                <h2>Thêm một tầng nội dung dành riêng cho thi công để chứng minh năng lực triển khai ngoài hiện trường, không dừng ở phần hình ảnh concept.</h2>
              </div>
              <div class="row">
                <% constructionShowcase.forEach(project => { %>
                  <div class="col-md-6 mb-4">
                    <article class="hk-progress-card">
                      <a href="/du-an/<%= project.slug %>">
                        <img src="<%= project.thumbnail || 'https://picsum.photos/seed/construction/700/520' %>" alt="<%= project.title %>" loading="lazy">
                        <div class="hk-progress-card__body">
                          <span class="hk-progress-card__eyebrow">Dự án thi công</span>
                          <h3><%= truncate(project.title, 78) %></h3>
                        </div>
                      </a>
                    </article>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } %>
          <div class="col-lg-5" data-aos="fade-left">
            <aside class="hk-proof-panel">
              <span class="hk-kicker">Điểm tin cậy</span>
              <h2>Khối nội dung phụ đóng vai trò chốt niềm tin, giữ nhịp chuyển đổi và làm đầy chiều sâu thương hiệu.</h2>
              <% if (leadTestimonial) { %>
                <blockquote class="hk-proof-quote">“<%= leadTestimonial.content %>”</blockquote>
                <div class="hk-proof-person">
                  <% if (leadTestimonial.avatar) { %><img src="<%= leadTestimonial.avatar %>" alt="<%= leadTestimonial.name %>"><% } %>
                  <div>
                    <strong><%= leadTestimonial.name %></strong>
                    <span><%= leadTestimonial.role || 'Khách hàng thực tế' %></span>
                  </div>
                </div>
              <% } %>
              <ul class="hk-proof-list">
                <li>Danh mục được chia rõ thành kiến trúc, nội thất và thi công để hành trình xem dự án mạch lạc hơn.</li>
                <li>Mỗi section đều có CTA hoặc đường dẫn rõ ràng để tăng cơ hội chuyển đổi thành cuộc gọi tư vấn.</li>
                <li>Bố cục ưu tiên cảm giác “nhiều bằng chứng thực tế”, rất phù hợp với ngành thiết kế và xây dựng cao cấp.</li>
              </ul>
              <a href="/lien-he" class="btn btn-primary btn-block">Nhận báo giá và tư vấn</a>
            </aside>
          </div>
        </div>
      </div>
    </section>
  <% } %>

  <% if (testimonials.length > 1) { %>
    <section class="hk-testimonials">
      <div class="container">
        <div class="hk-section-heading text-center" data-aos="fade-up">
          <span class="hk-kicker">Cảm nhận khách hàng</span>
          <h2>Một carousel đánh giá được giữ lại để homepage có nhịp chuyển mềm, tăng thêm bằng chứng xã hội cho thương hiệu.</h2>
        </div>
        <div class="owl-carousel testimonial-carousel hk-testimonial-carousel mt-4">
          <% testimonials.forEach(testimonial => { %>
            <article class="hk-testimonial-card">
              <div class="hk-testimonial-card__top">
                <% if (testimonial.avatar) { %><img src="<%= testimonial.avatar %>" alt="<%= testimonial.name %>"><% } %>
                <div>
                  <h3><%= testimonial.name %></h3>
                  <span><%= testimonial.role || 'Khách hàng của Hoàng Kim' %></span>
                </div>
              </div>
              <p><%= testimonial.content %></p>
            </article>
          <% }) %>
        </div>
      </div>
    </section>
  <% } %>

  <% if (latestPosts.length || hasMediaRail) { %>
    <section class="hk-news-media">
      <div class="container">
        <div class="row">
          <% if (latestPosts.length) { %>
            <div class="col-lg-8 mb-4" data-aos="fade-up">
              <div class="hk-section-heading hk-section-heading--split">
                <div>
                  <span class="hk-kicker">Tin tức - bản tin</span>
                  <h2>Khối tin tức giúp mặt tiền thương hiệu luôn có độ mới, đồng thời làm dày trải nghiệm đọc và tư vấn chuyên môn.</h2>
                </div>
                <a href="/tin-tuc" class="btn btn-outline-primary">Xem tất cả</a>
              </div>
              <div class="row">
                <% latestPosts.forEach(post => { %>
                  <div class="col-md-4 mb-4">
                    <article class="hk-news-card">
                      <a href="/tin-tuc/<%= post.slug %>" class="hk-news-card__media">
                        <img src="<%= post.thumbnail || 'https://picsum.photos/seed/news/500/340' %>" alt="<%= post.title %>" loading="lazy">
                      </a>
                      <div class="hk-news-card__body">
                        <span class="hk-news-card__time"><%= formatDate(post.createdAt) %></span>
                        <h3><a href="/tin-tuc/<%= post.slug %>"><%= truncate(post.title, 78) %></a></h3>
                        <p><%= truncate(post.excerpt || stripHtml(post.content), 115) %></p>
                      </div>
                    </article>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } %>
          <% if (hasMediaRail) { %>
            <div class="col-lg-<%= latestPosts.length ? '4' : '12' %>" data-aos="fade-left">
              <aside class="hk-brand-stack">
                <% if (pressLogos.length) { %>
                  <div class="hk-logo-block">
                    <span class="hk-kicker">Báo chí nói về chúng tôi</span>
                    <div class="owl-carousel press-carousel mt-3">
                      <% pressLogos.forEach(item => { %>
                        <div class="item"><img src="<%= item.logo %>" alt="<%= item.name %>" class="press-logo"></div>
                      <% }) %>
                    </div>
                  </div>
                <% } %>
                <% if (partners.length) { %>
                  <div class="hk-logo-block">
                    <span class="hk-kicker">Đối tác đồng hành</span>
                    <div class="owl-carousel partners-carousel mt-3">
                      <% partners.forEach(item => { %>
                        <div class="item"><img src="<%= item.logo %>" alt="<%= item.name %>" class="partner-logo"></div>
                      <% }) %>
                    </div>
                  </div>
                <% } %>
              </aside>
            </div>
          <% } %>
        </div>
      </div>
    </section>
  <% } %>

  <section class="hk-cta">
    <div class="container">
      <div class="hk-cta__shell" data-aos="fade-up">
        <div>
          <span class="hk-kicker">Kết nối tư vấn</span>
          <h2>Sẵn sàng xây một homepage giàu chiều sâu thương hiệu, rõ hành trình chuyển đổi và đủ tầm cho nhóm công trình cao cấp.</h2>
          <p><%= displayAddress %></p>
        </div>
        <div class="hk-cta__actions">
          <a href="/lien-he" class="btn btn-primary btn-lg">Gửi yêu cầu tư vấn</a>
          <a href="tel:<%= displayPhone.replace(/[^0-9+]/g, '') %>" class="btn btn-outline-primary btn-lg">Hotline: <%= displayPhone %></a>
        </div>
      </div>
    </div>
  </section>
</div>
