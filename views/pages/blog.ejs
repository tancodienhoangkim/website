<section class="page-header" style="background:linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.6)),url('https://picsum.photos/seed/blog/1920/400');background-size:cover;background-position:center;">
  <div class="container text-center text-white py-5"><h1>Tin tức</h1></div>
</section>
<section class="py-5"><div class="container"><div class="row">
  <div class="col-lg-8">
    <% posts.forEach(p => { %>
    <div class="card mb-4" data-aos="fade-up"><div class="row no-gutters">
      <div class="col-md-4"><img src="<%= p.thumbnail || 'https://via.placeholder.com/400x250' %>" alt="<%= p.title %>" class="card-img h-100" style="object-fit:cover;"></div>
      <div class="col-md-8"><div class="card-body">
        <h5 class="card-title"><a href="/tin-tuc/<%= p.slug %>"><%= p.title %></a></h5>
        <p class="text-muted small"><i class="fas fa-calendar"></i> <%= p.createdAt.toLocaleDateString('vi-VN') %></p>
        <p class="card-text"><%= p.excerpt || '' %></p>
        <a href="/tin-tuc/<%= p.slug %>" class="btn btn-sm btn-outline-primary">Đọc thêm</a>
      </div></div>
    </div></div>
    <% }) %>
    <% if (!posts.length) { %><p class="text-center text-muted py-5">Chưa có bài viết nào.</p><% } %>
    <%- include('../partials/pagination', { currentPage, totalPages, query: { category: selectedCategory } }) %>
  </div>
  <div class="col-lg-4">
    <div class="card"><div class="card-header"><h5 class="mb-0">Danh mục</h5></div>
      <div class="list-group list-group-flush">
        <a href="/tin-tuc" class="list-group-item list-group-item-action <%= !selectedCategory ? 'active' : '' %>">Tất cả</a>
        <% categories.forEach(c => { %><a href="/tin-tuc?category=<%= c._id %>" class="list-group-item list-group-item-action <%= selectedCategory === c._id.toString() ? 'active' : '' %>"><%= c.name %></a><% }) %>
      </div>
    </div>
  </div>
</div></div></section>
