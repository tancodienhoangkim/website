<% if (totalPages > 1) { %>
<nav class="mt-4">
  <ul class="pagination justify-content-center">
    <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>"><a class="page-link" href="?<%= new URLSearchParams({...query, page: currentPage - 1}).toString() %>">«</a></li>
    <% for (let i = 1; i <= totalPages; i++) { %>
    <li class="page-item <%= i === currentPage ? 'active' : '' %>"><a class="page-link" href="?<%= new URLSearchParams({...query, page: i}).toString() %>"><%= i %></a></li>
    <% } %>
    <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>"><a class="page-link" href="?<%= new URLSearchParams({...query, page: currentPage + 1}).toString() %>">»</a></li>
  </ul>
</nav>
<% } %>
