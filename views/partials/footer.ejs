<footer class="site-footer">
  <div class="container">
    <div class="row">
      <div class="col-lg-4 mb-4">
        <h5 class="footer-title"><%= settings.siteName || 'Tân Cổ Điển Hoàng Kim' %></h5>
        <p><i class="fas fa-map-marker-alt"></i> <%= settings.address || '' %></p>
        <p><i class="fas fa-phone-alt"></i> <%= settings.phone || '' %></p>
        <p><i class="fas fa-envelope"></i> <%= settings.email || '' %></p>
        <div class="footer-social mt-3">
          <% if (settings.facebook) { %><a href="<%= settings.facebook %>"><i class="fab fa-facebook-f"></i></a><% } %>
          <% if (settings.youtube) { %><a href="<%= settings.youtube %>"><i class="fab fa-youtube"></i></a><% } %>
          <% if (settings.zalo) { %><a href="https://zalo.me/<%= settings.zalo %>">Zalo</a><% } %>
        </div>
      </div>
      <div class="col-lg-4 mb-4">
        <h5 class="footer-title">Nhận tư vấn miễn phí</h5>
        <form class="footer-contact-form" id="footerContactForm">
          <input type="text" name="name" class="form-control mb-2" placeholder="Họ tên *" required>
          <input type="tel" name="phone" class="form-control mb-2" placeholder="Số điện thoại *" required>
          <input type="email" name="email" class="form-control mb-2" placeholder="Email">
          <textarea name="message" class="form-control mb-2" rows="2" placeholder="Nội dung" required></textarea>
          <button type="submit" class="btn btn-primary btn-block">Gửi yêu cầu</button>
          <div id="footerContactResult" class="mt-2"></div>
        </form>
      </div>
      <div class="col-lg-4 mb-4">
        <h5 class="footer-title">Bản đồ</h5>
        <% if (settings.googleMapsEmbed) { %><iframe src="<%= settings.googleMapsEmbed %>" width="100%" height="200" style="border:0;border-radius:4px;" allowfullscreen loading="lazy"></iframe><% } %>
      </div>
    </div>
    <hr class="footer-hr">
    <p class="text-center footer-copy"><%= settings.footerText || '' %></p>
  </div>
</footer>
